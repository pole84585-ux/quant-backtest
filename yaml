name: market_structure

on:
  schedule:
    - cron: '1 7 * * 1-5'

jobs:
  run:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v3

      - uses: actions/setup-python@v4
        with:
          python-version: 3.10

      - run: pip install -r requirements.txt

      - run: python main.py
        env:
          PUSHDEER_KEY: ${{ secrets.PUSHDEER_KEY }}
